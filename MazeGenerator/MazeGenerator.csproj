<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RunPostBuildEvent>OnBuildSuccess</RunPostBuildEvent>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Raylib-cs" Version="7.0.2" />
  </ItemGroup>

<ItemGroup>
  <FileWrites Include="$(ProjectDir)*.tscn" />
</ItemGroup>

<ItemGroup>
  <Compile Remove="Maze3DMegastructureBuilder.cs" />
</ItemGroup>

<Target Name="CustomClean" AfterTargets="Clean">
  <ItemGroup>
    <_FilesToDelete Include="$(ProjectDir)*.tscn" />
  </ItemGroup>
  <Delete Files="@(_FilesToDelete)" />
  <Message Importance="high" Text="Successfully cleaned custom .tscn files." />
</Target>

</Project>
